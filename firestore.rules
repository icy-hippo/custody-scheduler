rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function myFamilyId() {
      return userDoc(request.auth.uid).data.familyId;
    }

    function sameFamily(familyId) {
      return signedIn() && familyId != null && myFamilyId() == familyId;
    }

    function familyIdUnchanged() {
      return !('familyId' in resource.data)
        || resource.data.familyId == null
        || request.resource.data.familyId == resource.data.familyId;
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || sameFamily(resource.data.familyId);
      allow create: if isSelf(userId);
      allow update: if isSelf(userId) && familyIdUnchanged();
      allow delete: if false;
    }

    match /families/{familyId} {
      allow read: if sameFamily(familyId);
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.members;
      allow update: if sameFamily(familyId);
      allow delete: if false;
    }

    match /events/{eventId} {
      allow read: if sameFamily(resource.data.familyId);
      allow create: if sameFamily(request.resource.data.familyId)
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if sameFamily(resource.data.familyId);
    }

    match /custody/{userId} {
      allow read: if isSelf(userId) || sameFamily(userDoc(userId).data.familyId);
      allow write: if isSelf(userId);
    }

    match /parentInvites/{inviteId} {
      allow read: if signedIn()
        && (resource.data.invitedBy == request.auth.uid
          || resource.data.invitedEmail == request.auth.token.email);
      allow create: if signedIn() && request.resource.data.invitedBy == request.auth.uid;
      allow update: if signedIn()
        && (resource.data.invitedBy == request.auth.uid
          || resource.data.invitedEmail == request.auth.token.email);
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId is string;
    }

    match /expenses/{expenseId} {
      allow read, update, delete: if sameFamily(resource.data.familyId);
      allow create: if sameFamily(request.resource.data.familyId)
        && request.resource.data.paidBy == request.auth.uid;
    }

    match /messages/{messageId} {
      allow read: if sameFamily(resource.data.familyId);
      allow create: if sameFamily(request.resource.data.familyId)
        && request.resource.data.senderId == request.auth.uid;
    }

    match /routines/{routineId} {
      allow read, update, delete: if sameFamily(resource.data.familyId);
      allow create: if sameFamily(request.resource.data.familyId)
        && request.resource.data.createdBy == request.auth.uid;
    }

    match /familyMessages/{msgId} {
      allow read: if sameFamily(resource.data.familyId);
      allow create: if sameFamily(request.resource.data.familyId)
        && request.resource.data.senderId == request.auth.uid;
      allow update: if sameFamily(resource.data.familyId);
      allow delete: if false;
    }

    match /packLists/{listId} {
      allow read, write: if signedIn()
        && (listId == request.auth.uid || sameFamily(listId));
    }

    match /handoffNotes/{noteId} {
      allow read, update, delete: if sameFamily(resource.data.familyId);
      allow create: if sameFamily(request.resource.data.familyId)
        && request.resource.data.createdBy == request.auth.uid;
    }

    match /visualLabels/{labelId} {
      allow read, update, delete: if sameFamily(resource.data.familyId);
      allow create: if sameFamily(request.resource.data.familyId)
        && request.resource.data.createdBy == request.auth.uid;
    }
  }
}
